{
    "name": "api-produtos_camadas_imagem",
    "version": "1.0.0",
    "main": "app.ts",
    "scripts": {
        "start": "node dist/app.js",
        "dev": "nodemon src/app.ts --exec ts-node",
        "build": "tsc",
        "typeorm": "ts-node ./node_modules/typeorm/cli.js",
        "migration:generate": "npm run typeorm -- migration:generate -d src/data-source.ts",
        "migration:run": "npm run typeorm -- migration:run -d src/data-source.ts",
        "migration:revert": "npm run typeorm -- migration:revert -d src/data-source.ts",
        "prod:migrate": "node -r ts-node/register ./node_modules/typeorm/cli.js migration:run -d dist/data-source.js"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "description": "",
    "dependencies": {
        "bcrypt": "^6.0.0",
        "dotenv": "^17.4.1",
        "express": "^5.1.0",
        "multer": "^2.0.2",
        "pg": "^8.20.0",
        "reflect-metadata": "^0.2.2",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@types/bcrypt": "^6.0.0",
        "@types/express": "^5.0.3",
        "@types/multer": "^2.0.0",
        "@types/node": "^24.12.2",
        "@types/pg": "^8.15.5",
        "nodemon": "^3.1.10",
        "ts-node": "^10.9.2",
        "typeorm": "^0.3.28",
        "typescript": "^5.9.2"
    }
}
