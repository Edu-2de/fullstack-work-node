{
    "compilerOptions": {
        "types": ["node", "jest"],
        "module": "CommonJS",
        "target": "ES2020",
        "rootDir": "src",
        "outDir": "dist",
        "strict": true,
        "esModuleInterop": true,
        "emitDecoratorMetadata": true,
        "experimentalDecorators": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "declaration": true,
        "typeRoots": ["./node_modules/@types", "./src/@types"]
    },
    "ts-node": {
        "files": true,
        "transpileOnly": true,
        "compilerOptions": {
            "module": "CommonJS"
        }
    }
}
