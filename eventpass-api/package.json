{
    "name": "api-produtos_camadas_imagem",
    "version": "1.0.0",
    "main": "app.ts",
    "scripts": {
        "start": "npx typeorm migration:run -d dist/data-source.js && node dist/seeds/admin.seed.js && node dist/app.js",
        "dev": "nodemon -e ts --exec ts-node src/app.ts",
        "seed:admin": "ts-node src/seeds/admin.seed.ts",
        "build": "tsc",
        "typeorm": "ts-node ./node_modules/typeorm/cli.js",
        "migration:generate": "npm run typeorm -- migration:generate -d src/data-source.ts src/migrations/InitialSchema",
        "migration:run": "npm run typeorm -- migration:run -d src/data-source.ts",
        "migration:revert": "npm run typeorm -- migration:revert -d src/data-source.ts",
        "prod:migrate": "node -r ts-node/register ./node_modules/typeorm/cli.js migration:run -d dist/data-source.js"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "description": "",
    "dependencies": {
        "bcrypt": "^6.0.0",
        "cors": "^2.8.6",
        "dotenv": "^17.4.1",
        "express": "^5.1.0",
        "express-rate-limit": "^8.4.0",
        "helmet": "^8.1.0",
        "jsonwebtoken": "^9.0.3",
        "multer": "^2.1.1",
        "pg": "^8.20.0",
        "reflect-metadata": "^0.2.2",
        "winston": "^3.19.0",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@types/bcrypt": "^6.0.0",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.3",
        "@types/jest": "^30.0.0",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/multer": "^2.1.0",
        "@types/node": "^24.12.2",
        "@types/pg": "^8.15.5",
        "jest": "^30.3.0",
        "nodemon": "^3.1.10",
        "ts-jest": "^29.4.9",
        "ts-node": "^10.9.2",
        "typeorm": "^0.3.28",
        "typescript": "^5.9.2"
    }
}
